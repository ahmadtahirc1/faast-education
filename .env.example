# Admin credentials for the protected dashboard
# Copy this file to .env.local or your deployment platform secrets.
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Supabase (Project Settings -> API in the Supabase dashboard)
# SUPABASE_SECRET_KEY must never be exposed to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
